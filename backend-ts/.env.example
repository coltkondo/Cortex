# Leave empty to use mock AI (no API calls)
# Get a free Gemini API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_api_key_here

# Set to "true" to force mock mode even with API key
USE_MOCK_AI=false

# Database
DATABASE_PATH=./cortex.db

# Server
PORT=8000
NODE_ENV=development

# CORS
CORS_ORIGINS=http://localhost:5173

# Redis Caching (Optional but Recommended for Production)
# Leave empty to run without caching
# For local Redis: redis://localhost:6379
# For Redis Cloud/Heroku: redis://user:password@host:port
REDIS_URL=
REDIS_ENABLED=true
